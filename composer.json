{
    "name": "laravel/laravel",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "type": "project",
    "repositories": [
        {
            "url": "https://github.com/dineshsailor/nWidart-laravel-menus",
            "type": "git"
        }
    ],
    "require": {
        "php": "^8.2",
        "aloha/twilio": "^4.0",
        "arcanedev/log-viewer": "^10.1",
        "automattic/woocommerce": "^3.0",
        "barryvdh/laravel-dompdf": "^2.1",
        "bernskioldmedia/laravel-autotranslate": "^1.1",
        "caujasutom/laravel-optimizer": "dev-master",
        "composer/semver": "^3.0",
        "consoletvs/charts": "^6.7",
        "giggsey/libphonenumber-for-php": "^8.12",
        "guzzlehttp/guzzle": "^7.2",
        "jenssegers/agent": "^2.6",
        "knox/pesapal": "^1.5",
        "laravel/framework": "^11.14",
        "laravel/legacy-factories": "^1.4",
        "laravel/passport": "^12.0",
        "laravel/tinker": "^2.9",
        "laravel/ui": "^4.4",
        "laravelcollective/html": "^6.4",
        "league/flysystem-aws-s3-v3": "^3.0",
        "maatwebsite/excel": "^3.1.8",
        "milon/barcode": "^11.0",
        "mpdf/mpdf": "^8.1",
        "nwidart/laravel-menus": "6.0.x-dev",
        "nwidart/laravel-modules": "^9.0",
        "openai-php/laravel": "^0.9",
        "pusher/pusher-php-server": "7.0.2",
        "razorpay/razorpay": "2.*",
        "rtippin/janus-client": "^1.3.0",
        "rtippin/messenger": "^1.23.0",
        "rtippin/messenger-ui": "^2.7.2",
        "spatie/flysystem-dropbox": "^2.0",
        "spatie/laravel-activitylog": "^4.8",
        "spatie/laravel-backup": "^8.6",
        "spatie/laravel-image-optimizer": "^1.8",
        "spatie/laravel-package-tools": "^1.16",
        "spatie/laravel-permission": "^6.2",
        "spatie/laravel-responsecache": "^7.5",
        "srmklive/paypal": "^3.0",
        "stichoza/google-translate-php": "^5.1",
        "stripe/stripe-php": "^7.122",
        "unicodeveloper/laravel-paystack": "^1.2",
        "vluzrmos/language-detector": "^2.3",
        "yajra/laravel-datatables-oracle": "^11.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.10",
        "fakerphp/faker": "^1.23",
        "knuckleswtf/scribe": "^4.33",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0.1"
    },
    "autoload": {
        "files": [
            "app/Http/helpers.php"
        ],
        "classmap": [
            "database"
        ],
        "psr-4": {
            "App\\": "app/",
            "Modules\\": "Modules/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-root-package-install": [
            "php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "php artisan key:generate"
        ],
        "post-install-cmd": [
            "Illuminate\\Foundation\\ComposerScripts::postInstall"
        ],
        "post-update-cmd": [
            "Illuminate\\Foundation\\ComposerScripts::postUpdate",
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "ocramius/package-versions": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
